{
  "name": "ro-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "dev:game": "tsx game-server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:game\"",
    "build": "esbuild game-server/index.ts --bundle --platform=node --packages=external --outdir=game-server/dist && next build && esbuild server.ts --bundle --platform=node --packages=external --outdir=dist",
    "start": "node game-server/dist/index.js",
    "lint": "next lint"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-react": "^0.470.0",
    "nanoid": "^5.0.9",
    "next": "15.1.11",
    "peerjs": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "three": "^0.170.0",
    "three.quarks": "^0.11.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/peerjs": "^1.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.170.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "9.39.1",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "4.1.11",
    "tsx": "^4.22.0",
    "typescript": "5.9.3"
  }
}
